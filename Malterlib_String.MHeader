Import "../Core/Lib_Malterlib.MTarget"

Property
{
	!!MalterlibEnableInternalTests true

	MalterlibBoostModules =+ [
		"algorithm"
		, "spirit"
		, "config"
		, "phoenix"
		, "predef"
		, "proto"
		, "core"
		, "endian"
		, "mpl"
		, "type_traits"
		, "utility"
		, "fusion"
		, "typeof"
		, "range"
		, "iterator"
		, "detail"
		, "concept_check"
		, "foreach"
		, "variant"
		, "type_index"
		, "container_hash"
		, "math"
		, "functional"
		, "integer"
		, "regex"
		, "throw_exception"
		, "optional"
		, "function_types"
		, "array"
		, "smart_ptr"
		, "iostreams"
		, "lexical_cast"
		, "numeric_conversion"
		, "container"
	]
}

%Group "{Malterlib}/{Lib_Malterlib_String}"
{
	%Group "String"
	{
		%Group "Include"
		{
			Compile.Type "C++"
			{
				!!DocumentationEnabled true
			}
			%File "Include/Mib/String/^*"
		}
		%File "Source/^*"
		%Group "Documentation"
		{
			%File "Documentation/*"
		}
	}
}


Property
{
	MalterlibLibrary_String define bool = MalterlibLibrary_All
	MalterlibSubLibraries =+ "String"
	{
		!!MalterlibLibrary_String true
	}
//	MalterlibSubLibrarySeparate_Lib_Malterlib_String define bool = true
	MalterlibIncludeRoots =+ "Include"->MakeAbsolute()
	{
		!!MalterlibLibrary_String true
	}
}

%Group "{Test}/{Malterlib_String}"
{
	Target.CxxLanguage "C++20" // Workaround Boost Spirit issue
	{
		&
		{
			LanguageFamily "Native"
			GeneratorFamily "Xcode"
		}
	}
	
	Compile
	{
		!!CompileDialect "C"
		PreprocessorDefines =+ "_SILENCE_CXX17_ITERATOR_BASE_CLASS_DEPRECATION_WARNING"
		{
			!!PlatformFamily "Windows"
		}
	}
}

Property
{
	!!MalterlibEnableInternalTests true
	
	MalterlibTests =+ "Malterlib_String"
	MalterlibTestFiles_Malterlib_String define [type(CEntity)] = ["Test/*"->MakeAbsolute()]
	MalterlibTestExtraGroups_Malterlib_String define [string] = ["{Test}/{Malterlib_String}"]
}
